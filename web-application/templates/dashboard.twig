{% extends 'layout.twig' %}
{% block title %}My Dashboard | Studio Doki{% endblock %}
{% block body_class %}dashboard-page{% endblock %}
{% block content %}
<main class="user-dashboard">

    {# ── Greeting + actions ───────────────────────────────────── #}
    <header class="dashboard-head">
        <div>
            <p class="eyebrow">Welcome back</p>
            <h1>Hello, {{ user.firstName }}!</h1>
            <p class="dashboard-subtitle">Manage your appointments and reviews</p>
        </div>
        <div class="dashboard-actions">
            <a class="btn" href="{{ path('/book?new=1') }}">+ Book again</a>
            <form method="post" action="{{ path('/logout') }}" style="display:inline;">
                <button type="submit" class="btn outline">Log out</button>
            </form>
        </div>
    </header>

    {% if flash %}
        <div class="flash flash-{{ flash.type }}">{{ flash.message }}</div>
    {% endif %}

    {# ── Layout: sidebar profile + tabbed content ────────────── #}
    <div class="dashboard-layout">

        {# Profile sidebar (always visible) #}
        <aside class="profile-card">
            <p class="profile-label">Account Information</p>
            <div class="profile-avatar">{{ user.firstName|slice(0,1)|upper }}{{ user.lastName|slice(0,1)|upper }}</div>
            <h2>{{ user.firstName }} {{ user.lastName }}</h2>
            <dl class="account-info">
                <div>
                    <dt>Email</dt>
                    <dd>{{ user.email }}</dd>
                </div>
                <div>
                    <dt>Phone</dt>
                    <dd>{{ user.phoneNumber|default('Not provided') }}</dd>
                </div>
                <div>
                    <dt>Account Type</dt>
                    <dd>{{ user.role|default('client')|capitalize }}</dd>
                </div>
            </dl>

            <hr>

            <div class="profile-stats">
                <div><strong>{{ upcoming|length }}</strong><span>Upcoming</span></div>
                <div><strong>{{ past|length }}</strong><span>History</span></div>
                <div><strong>{{ myReviews|length }}</strong><span>Reviews left</span></div>
            </div>

            <hr>

            <p class="muted small">
                <strong>Studio Doki policy:</strong> please arrive 5 minutes early.
                Cancellations require 48 hours notice.
            </p>
        </aside>

        {# Tabbed content #}
        <section class="dashboard-main">
            <nav class="tabs" aria-label="Dashboard sections">
                <a class="{{ tab == 'upcoming' ? 'active' : '' }}" href="{{ path('/dashboard') }}?tab=upcoming">
                    Upcoming <span class="tab-count">{{ upcoming|length }}</span>
                </a>
                <a class="{{ tab == 'past' ? 'active' : '' }}" href="{{ path('/dashboard') }}?tab=past">
                    Booking history <span class="tab-count">{{ past|length }}</span>
                </a>
            </nav>

            <div class="tab-panel">

                {# ── UPCOMING ──────────────────────────────── #}
                {% if tab == 'upcoming' %}
                    {% if upcoming|length == 0 %}
                        <div class="empty-card">
                            <h2>No upcoming appointments</h2>
                            <p class="muted">Ready for your next visit? Book a service in just a few clicks.</p>
                            <a class="btn" href="{{ path('/book?new=1') }}">Book now</a>
                        </div>
                    {% else %}
                        <div class="cards-grid">
                            {% for appt in upcoming %}
                                <article class="appt-card status-{{ appt.status }}">
                                    <header class="appt-card-head">
                                        <h3>{{ appt.serviceName }}</h3>
                                        <span class="status-chip status-chip-{{ appt.status }}">{{ appt.status|capitalize }}</span>
                                    </header>
                                    <dl class="appt-details">
                                        <div class="appt-field"><dt>Date</dt><dd>{{ appt.date }}</dd></div>
                                        <div class="appt-field"><dt>Time</dt><dd>{{ appt.time }}</dd></div>
                                        <div class="appt-field"><dt>Location</dt><dd>Studio Doki</dd></div>
                                        {% if appt.notes %}
                                            <div class="appt-field appt-field-wide"><dt>Notes</dt><dd>{{ appt.notes }}</dd></div>
                                        {% endif %}
                                    </dl>
                                </article>
                            {% endfor %}
                        </div>
                    {% endif %}

                {# ── BOOKING HISTORY (the ONLY place you can leave a review) ── #}
                {% elseif tab == 'past' %}
                    {% if reviewErrors.general is defined %}
                        <div class="flash flash-error">{{ reviewErrors.general }}</div>
                    {% endif %}

                    {% if past|length == 0 %}
                        <div class="empty-card">
                            <h2>No past visits yet</h2>
                            <p class="muted">Once you've completed an appointment you'll see it here, with the option to leave a review.</p>
                        </div>
                    {% else %}
                        <div class="history-list">
                            {% for appt in past %}
                                <article class="history-item status-{{ appt.status }}">
                                    <header class="history-head">
                                        <div>
                                            <h3>{{ appt.serviceName }}</h3>
                                            <p class="muted">{{ appt.date }} · {{ appt.time }}</p>
                                        </div>
                                        <span class="status-chip status-chip-{{ appt.status }}">{{ appt.status|capitalize }}</span>
                                    </header>

                                    {% if appt.status == 'completed' %}
                                        {% if reviewedIds[appt.id] is defined %}
                                            {% set myReview = reviewedIds[appt.id] %}
                                            <div class="my-review-inline">
                                                <header>
                                                    <span class="check">✓</span>
                                                    <strong>You reviewed this visit</strong>
                                                    <span class="stars">{{ myReview.rating }}/5 ★</span>
                                                    <span class="muted">· {{ myReview.reviewDate }}</span>
                                                </header>
                                                {% if myReview.comment %}
                                                    <p class="my-review-comment">{{ myReview.comment }}</p>
                                                {% endif %}
                                                {% if myReview.reply %}
                                                    <div class="review-reply existing">
                                                        <strong>Studio Doki replied{% if myReview.repliedAt %} on {{ myReview.repliedAt|slice(0,10) }}{% endif %}:</strong>
                                                        <p>{{ myReview.reply }}</p>
                                                    </div>
                                                {% endif %}
                                            </div>
                                        {% else %}
                                            <details class="review-form-wrap">
                                                <summary>Leave a review</summary>
                                                <form method="post" action="{{ path('/dashboard/review') }}" class="review-form"
                                                      data-confirm="Post this review? It will be visible to the studio."
                                                      data-confirm-title="Post review">
                                                    <input type="hidden" name="appointmentID" value="{{ appt.id }}">

                                                    <fieldset class="rating-input">
                                                        <legend>Your rating</legend>
                                                        {% for n in [5, 4, 3, 2, 1] %}
                                                            <input type="radio" id="r-{{ appt.id }}-{{ n }}" name="rating" value="{{ n }}"
                                                                   {{ (reviewForm.appointmentID|default(0) == appt.id and reviewForm.rating == n) ? 'checked' : '' }}
                                                                   required>
                                                            <label for="r-{{ appt.id }}-{{ n }}" title="{{ n }} star{{ n > 1 ? 's' : '' }}">★</label>
                                                        {% endfor %}
                                                    </fieldset>
                                                    {% if reviewErrors.rating is defined %}<p class="error">{{ reviewErrors.rating }}</p>{% endif %}

                                                    <textarea name="comment" rows="3" maxlength="255"
                                                              placeholder="How was your experience?">{{ reviewForm.appointmentID|default(0) == appt.id ? reviewForm.comment|default('') : '' }}</textarea>
                                                    {% if reviewErrors.comment is defined %}<p class="error">{{ reviewErrors.comment }}</p>{% endif %}

                                                    <button type="submit" class="btn-sm">Post review</button>
                                                </form>
                                            </details>
                                        {% endif %}
                                    {% endif %}
                                </article>
                            {% endfor %}
                        </div>
                    {% endif %}

                {% endif %}

            </div>
        </section>
    </div>
</main>

{% include 'partials/confirm-modal.twig' %}
{% endblock %}
