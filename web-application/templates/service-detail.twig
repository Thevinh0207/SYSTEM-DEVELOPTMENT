{% extends 'layout.twig' %}
{% block title %}{{ service.name|default('Service Details') }} | Studio Doki{% endblock %}
{% block content %}
<main class="detail-page">
    <div class="crumbs"><a href="{{ path('/services') }}">Services</a> <span>&gt;</span> {{ service.category|default('Service') }} <span>&gt;</span> {{ service.name|default('Details') }}</div>
    <section class="detail-grid">
        <div>
            <h1>{{ service.name }}</h1>
            <p class="meta"><span>{{ service.price }}</span> {{ service.duration }}</p>
            <p>{{ service.description }}</p>
            <p>Vivian will confirm the final design, shape, and finish with you before the service begins so the appointment fits your preferred style.</p>
            <a class="btn wide" href="{{ path('/book?service=' ~ service.id) }}">Book This Service</a>

            <section class="service-reviews">
                <h2>Customer Reviews</h2>
                {% for review in reviews %}
                    <article class="service-review">
                        <strong>{{ review.authorName }}</strong>
                        <span>{{ review.rating }}/5</span>
                        {% if review.comment %}<p>{{ review.comment }}</p>{% endif %}
                    </article>
                {% else %}
                    <p class="muted">No reviews for this service yet.</p>
                {% endfor %}
            </section>
        </div>
        <img src="{{ images.brush }}" alt="{{ service.name }}">
    </section>
</main>
{% endblock %}
