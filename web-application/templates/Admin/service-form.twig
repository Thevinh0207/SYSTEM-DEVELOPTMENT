{% extends 'layout.twig' %}
{% block title %}{{ mode == 'edit' ? 'Edit Service' : 'New Service' }} | Admin{% endblock %}
{% block body_class %}admin-page{% endblock %}
{% block nav %}{% endblock %}
{% block content %}
<main class="admin-form-page">
    <a class="back-link" href="{{ path('/admin/services') }}">← Back to services</a>
    <h1>{{ mode == 'edit' ? 'Edit Service' : 'Create New Service' }}</h1>

    <form method="post"
          action="{{ mode == 'edit' ? path('/admin/services/' ~ id ~ '/edit') : path('/admin/services/new') }}"
          class="admin-form"
          {% if mode == 'edit' %}data-confirm="Save these changes? This will update the service in the database." data-confirm-title="Confirm changes"{% endif %}>

        <label>
            Service Name
            <input type="text" name="name" value="{{ service.name|default('') }}" required>
            {% if errors.name is defined %}<span class="error">{{ errors.name }}</span>{% endif %}
        </label>

        <label>
            Category
            <select name="categoryId" required>
                <option value="">— Select a category —</option>
                {% for c in categories %}
                    <option value="{{ c.id }}" {{ service.categoryId|default(0) == c.id ? 'selected' : '' }}>{{ c.name }}</option>
                {% endfor %}
            </select>
            {% if errors.categoryId is defined %}<span class="error">{{ errors.categoryId }}</span>{% endif %}
            <span class="hint"><a href="{{ path('/admin/service-categories') }}">Manage categories →</a></span>
        </label>

        <label>
            Description
            <textarea name="description" rows="3" required>{{ service.description|default('') }}</textarea>
            {% if errors.description is defined %}<span class="error">{{ errors.description }}</span>{% endif %}
        </label>

        <div class="form-row">
            <label>
                Price ($)
                <input type="number" step="0.01" min="0" name="price" value="{{ service.price|default('') }}" required>
                {% if errors.price is defined %}<span class="error">{{ errors.price }}</span>{% endif %}
            </label>

            <label>
                Duration (minutes)
                <input type="number" min="1" name="duration" value="{{ service.duration|default('') }}" required>
                {% if errors.duration is defined %}<span class="error">{{ errors.duration }}</span>{% endif %}
            </label>
        </div>

        <div class="form-actions">
            <a class="btn outline" href="{{ path('/admin/services') }}">Cancel</a>
            <button type="submit" class="btn">{{ mode == 'edit' ? 'Save changes' : 'Create service' }}</button>
        </div>
    </form>
</main>
{% include 'partials/confirm-modal.twig' %}
{% endblock %}
