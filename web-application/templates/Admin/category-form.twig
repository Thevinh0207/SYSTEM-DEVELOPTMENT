{% extends 'layout.twig' %}
{% block title %}{{ mode == 'edit' ? 'Edit' : 'New' }} Service Category | Admin{% endblock %}
{% block body_class %}admin-page{% endblock %}
{% block nav %}{% endblock %}
{% block content %}
<main class="admin-form-page">
    <a class="back-link" href="{{ path('/admin/service-categories') }}">← Back to service categories</a>
    <h1>{{ mode == 'edit' ? 'Edit Service Category' : 'New Service Category' }}</h1>

    <form method="post"
          action="{{ mode == 'edit' ? path('/admin/service-categories/' ~ id ~ '/edit') : path('/admin/service-categories/new') }}"
          class="admin-form"
          {% if mode == 'edit' %}data-confirm="Save changes to this category? Existing services that use it will keep working." data-confirm-title="Confirm changes"{% endif %}>

        <label>
            Name
            <input type="text" name="name" value="{{ category.name|default('') }}" maxlength="50" required>
            {% if errors.name is defined %}<span class="error">{{ errors.name }}</span>{% endif %}
        </label>

        <label>
            Sort order (lower = listed first)
            <input type="number" name="sortOrder" value="{{ category.sortOrder|default(0) }}">
        </label>

        <div class="form-actions">
            <a class="btn outline" href="{{ path('/admin/service-categories') }}">Cancel</a>
            <button type="submit" class="btn">{{ mode == 'edit' ? 'Save changes' : 'Add category' }}</button>
        </div>
    </form>
</main>
{% include 'partials/confirm-modal.twig' %}
{% endblock %}
