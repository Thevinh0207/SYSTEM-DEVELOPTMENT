{% extends 'layout.twig' %}
{% block title %}About | Studio Doki{% endblock %}
{% block content %}
<main class="about-page">
    <section class="about-hero">
        <div class="about-hero-text">
            <p class="eyebrow">About the Artist</p>
            <h1>Hi, I'm Vivian.</h1>
            <p class="lede">
                Twenty-three, Montreal-born, and obsessed with the way a perfect set
                of nails can make someone walk out the door feeling like the main character.
            </p>
        </div>
        <div class="about-hero-image">
            <img src="{{ images.brush }}" alt="Vivian working on a client's nails">
        </div>
    </section>

    <section class="about-story">
        {% for section in sections|default([]) %}
            <div class="story-block">
                <h2>{{ section.heading }}</h2>
                <p>{{ section.body|nl2br }}</p>
            </div>
        {% else %}
            <p class="muted" style="grid-column: 1 / -1; text-align: center; padding: 40px;">
                No content yet — check back soon.
            </p>
        {% endfor %}
    </section>

    <section class="about-cta">
        <h2>Come hang out.</h2>
        <p>I'd love to do your nails.</p>
        <a class="btn" href="{{ path('/book?new=1') }}">Book an appointment</a>
    </section>
</main>
{% endblock %}
