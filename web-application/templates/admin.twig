{% extends 'layout.twig' %}
{% block title %}Admin | Studio Doki{% endblock %}
{% block body_class %}admin-page{% endblock %}
{% block nav %}{% endblock %}
{% block content %}
<main class="admin-layout">
    <aside>
        <span class="admin-pill">ADMIN ONLY</span>
        <h2>Studio Doki</h2>
        {% if currentUser %}
            <p class="admin-user muted">{{ currentUser.firstName }} {{ currentUser.lastName }}</p>
        {% endif %}
        <a class="{{ section == 'appointments' ? 'active' : '' }}" href="{{ path('/admin/appointments') }}">Appointments</a>
        <a class="{{ section == 'services'     ? 'active' : '' }}" href="{{ path('/admin/services') }}">Services</a>
        <a class="{{ section == 'payments'     ? 'active' : '' }}" href="{{ path('/admin/payments') }}">Payments</a>
        <a class="{{ section == 'reviews'      ? 'active' : '' }}" href="{{ path('/admin/reviews') }}">Reviews</a>
        <a class="{{ section == 'service-categories' ? 'active' : '' }}" href="{{ path('/admin/service-categories') }}">Service Categories</a>
        <a class="{{ section == 'faq'                ? 'active' : '' }}" href="{{ path('/admin/faq') }}">FAQ</a>
        <a class="{{ section == 'about'              ? 'active' : '' }}" href="{{ path('/admin/about') }}">About</a>
        <form method="post" action="{{ path('/logout') }}" class="admin-logout">
            <button type="submit" class="btn outline">Log out</button>
        </form>
    </aside>

    <section>
        {% if flash %}
            <div class="flash flash-{{ flash.type }}">{{ flash.message }}</div>
        {% endif %}

        {# ── SERVICES ──────────────────────────────────────────────── #}
        {% if section == 'services' %}
            <div class="admin-section-head">
                <div>
                    <h1>Services</h1>
                    <p class="section-subtitle">{{ services|default([])|length }} total</p>
                </div>
                <a href="{{ path('/admin/services/new') }}" class="btn">+ Add</a>
            </div>

            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr><th>Name</th><th>Category</th><th>Price</th><th>Duration</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                    {% for service in services|default([]) %}
                        <tr>
                            <td><strong>{{ service.name }}</strong><br><span class="muted">{{ service.description }}</span></td>
                            <td>{{ service.category }}</td>
                            <td>${{ service.price|number_format(2) }}</td>
                            <td>{{ service.duration }} min</td>
                            <td class="action-cell">
                                <a class="btn-sm" href="{{ path('/admin/services/' ~ service.id ~ '/edit') }}">Edit</a>
                                <form method="post"
                                      action="{{ path('/admin/services/' ~ service.id ~ '/delete') }}"
                                      data-confirm="Delete the “{{ service.name }}” service? This cannot be undone."
                                      data-confirm-title="Delete service"
                                      data-confirm-danger
                                      style="display:inline;">
                                    <button type="submit" class="btn-sm btn-sm-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="5" class="muted">No services yet.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

        {# ── PAYMENTS ──────────────────────────────────────────────── #}
        {% elseif section == 'payments' %}
            <h1>Payment History</h1>
            <p class="section-subtitle">{{ payments|default([])|length }} total</p>

            {% if insights and insights.totals %}
                <div class="insights-grid">
                    <div class="insight-card">
                        <span class="insight-label">Total revenue</span>
                        <strong class="insight-value">${{ insights.totals.total_revenue|number_format(2) }}</strong>
                    </div>
                    <div class="insight-card">
                        <span class="insight-label">Paid</span>
                        <strong class="insight-value">${{ insights.totals.revenue_paid|number_format(2) }}</strong>
                    </div>
                    <div class="insight-card">
                        <span class="insight-label">Pending</span>
                        <strong class="insight-value">${{ insights.totals.revenue_pending|number_format(2) }}</strong>
                    </div>
                    <div class="insight-card">
                        <span class="insight-label">Avg. payment</span>
                        <strong class="insight-value">${{ insights.totals.average_amount|number_format(2) }}</strong>
                    </div>
                </div>
            {% endif %}

            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr><th>Payer</th><th>Email / Phone</th><th>Type</th><th>Amount</th><th>Status</th><th>When</th></tr>
                    </thead>
                    <tbody>
                    {% for p in payments|default([]) %}
                        <tr>
                            <td>
                                <strong>{{ p.payerName }}</strong>
                                {% if p.payerType == 'guest' %}
                                    <span class="tag tag-guest">Guest</span>
                                {% else %}
                                    <span class="tag tag-client">Client</span>
                                {% endif %}
                            </td>
                            <td>
                                <span class="muted">{{ p.payerEmail|default('—') }}</span><br>
                                <span class="muted">{{ p.payerPhone|default('—') }}</span>
                            </td>
                            <td>{{ p.paymentType }}</td>
                            <td>${{ p.paymentAmount|number_format(2) }}</td>
                            <td><span class="status-chip status-chip-{{ p.paymentStatus == 'paid' ? 'confirmed' : 'pending' }}">{{ p.paymentStatus|capitalize }}</span></td>
                            <td><span class="muted">{{ p.created_at|slice(0,16) }}</span></td>
                        </tr>
                    {% else %}
                        <tr><td colspan="6" class="muted">No payments recorded.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

        {# ── REVIEWS ───────────────────────────────────────────────── #}
        {% elseif section == 'reviews' %}
            <h1>Customer Reviews</h1>
            <p class="section-subtitle">{{ reviews|default([])|length }} total</p>

            {% for review in reviews|default([]) %}
                <article class="review-card">
                    <header class="review-head">
                        <div>
                            <strong>{{ review.authorName|default('Anonymous') }}</strong>
                            <span class="muted">· {{ review.serviceName|default('') }} · {{ review.reviewDate }}</span>
                        </div>
                        <span class="stars">{{ review.rating }}/5 ★</span>
                    </header>
                    <p class="review-comment">{{ review.comment|default('(no comment)') }}</p>

                    {% if review.reply %}
                        <div class="review-reply existing">
                            <strong>Studio Doki replied{% if review.repliedAt %} on {{ review.repliedAt|slice(0,10) }}{% endif %}:</strong>
                            <p>{{ review.reply }}</p>
                        </div>
                    {% endif %}

                    <details class="reply-form-wrap">
                        <summary>{{ review.reply ? 'Edit reply' : 'Reply to this review' }}</summary>
                        <form method="post"
                              action="{{ path('/admin/reviews/' ~ review.id ~ '/reply') }}"
                              data-confirm="Save this reply? It will be visible alongside the review."
                              data-confirm-title="Save reply"
                              class="reply-form">
                            <textarea name="reply" rows="3" maxlength="500" placeholder="Write your reply…">{{ review.reply|default('') }}</textarea>
                            <div class="reply-actions">
                                {% if review.reply %}
                                    <button type="submit"
                                            name="reply" value=""
                                            class="btn-sm btn-sm-danger"
                                            formnovalidate
                                            data-confirm="Remove your reply? The customer will no longer see it."
                                            data-confirm-title="Delete reply"
                                            data-confirm-danger>
                                        Delete reply
                                    </button>
                                {% endif %}
                                <button type="submit" class="btn-sm">{{ review.reply ? 'Update reply' : 'Post reply' }}</button>
                            </div>
                        </form>
                    </details>
                </article>
            {% else %}
                <p class="muted">No reviews yet.</p>
            {% endfor %}

        {# ── SERVICE CATEGORIES ───────────────────────────────────── #}
        {% elseif section == 'service-categories' %}
            <div class="admin-section-head">
                <div>
                    <h1>Service Categories</h1>
                    <p class="section-subtitle">{{ serviceCategories|default([])|length }} total</p>
                </div>
                <a href="{{ path('/admin/service-categories/new') }}" class="btn">+ Add</a>
            </div>
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead><tr><th>Order</th><th>Name</th><th>Actions</th></tr></thead>
                    <tbody>
                    {% for c in serviceCategories|default([]) %}
                        <tr>
                            <td>{{ c.sortOrder }}</td>
                            <td><strong>{{ c.name }}</strong></td>
                            <td class="action-cell">
                                <a class="btn-sm" href="{{ path('/admin/service-categories/' ~ c.id ~ '/edit') }}">Edit</a>
                                <form method="post"
                                      action="{{ path('/admin/service-categories/' ~ c.id ~ '/delete') }}"
                                      data-confirm="Delete the “{{ c.name }}” category? This will fail if any services still use it."
                                      data-confirm-title="Delete category"
                                      data-confirm-danger
                                      style="display:inline;">
                                    <button type="submit" class="btn-sm btn-sm-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="3" class="muted">No categories yet.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

        {# ── FAQ ──────────────────────────────────────────────────── #}
        {% elseif section == 'faq' %}
            <div class="admin-section-head">
                <div>
                    <h1>FAQ Entries</h1>
                    <p class="section-subtitle">{{ faqs|default([])|length }} total</p>
                </div>
                <a href="{{ path('/admin/faq/new') }}" class="btn">+ Add</a>
            </div>

            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr><th>Order</th><th>Category</th><th>Question</th><th>Answer (preview)</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                    {% for faq in faqs|default([]) %}
                        <tr>
                            <td>{{ faq.sortOrder }}</td>
                            <td>{{ faq.category }}</td>
                            <td><strong>{{ faq.question }}</strong></td>
                            <td><span class="muted">{{ faq.answer|slice(0, 90) }}{{ faq.answer|length > 90 ? '…' : '' }}</span></td>
                            <td class="action-cell">
                                <a class="btn-sm" href="{{ path('/admin/faq/' ~ faq.id ~ '/edit') }}">Edit</a>
                                <form method="post"
                                      action="{{ path('/admin/faq/' ~ faq.id ~ '/delete') }}"
                                      data-confirm="Delete this FAQ entry? This cannot be undone."
                                      data-confirm-title="Delete FAQ"
                                      data-confirm-danger
                                      style="display:inline;">
                                    <button type="submit" class="btn-sm btn-sm-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="5" class="muted">No FAQ entries yet.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

        {# ── ABOUT ────────────────────────────────────────────────── #}
        {% elseif section == 'about' %}
            <div class="admin-section-head">
                <div>
                    <h1>About Page Sections</h1>
                    <p class="section-subtitle">{{ aboutSections|default([])|length }} story blocks</p>
                </div>
                <a href="{{ path('/admin/about/new') }}" class="btn">+ Add</a>
            </div>

            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr><th>Order</th><th>Heading</th><th>Body (preview)</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                    {% for sec in aboutSections|default([]) %}
                        <tr>
                            <td>{{ sec.sortOrder }}</td>
                            <td><strong>{{ sec.heading }}</strong></td>
                            <td><span class="muted">{{ sec.body|slice(0, 100) }}{{ sec.body|length > 100 ? '…' : '' }}</span></td>
                            <td class="action-cell">
                                <a class="btn-sm" href="{{ path('/admin/about/' ~ sec.id ~ '/edit') }}">Edit</a>
                                <form method="post"
                                      action="{{ path('/admin/about/' ~ sec.id ~ '/delete') }}"
                                      data-confirm="Delete this About section?"
                                      data-confirm-title="Delete section"
                                      data-confirm-danger
                                      style="display:inline;">
                                    <button type="submit" class="btn-sm btn-sm-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4" class="muted">No About sections yet.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

        {# ── APPOINTMENTS ──────────────────────────────────────────── #}
        {% else %}
            <div class="admin-section-head">
                <div>
                    <h1>Appointments</h1>
                    <p class="section-subtitle">{{ appointments|default([])|length }} total</p>
                </div>
                <a href="{{ path('/admin/appointments/new') }}" class="btn">+ Add</a>
            </div>

            <div class="appt-grid">
                {% for appt in appointments|default([]) %}
                    <article class="appt-card status-{{ appt.status }}">
                        <header class="appt-card-head">
                            <div class="appt-customer">
                                <h3>{{ appt.customerName }}</h3>
                                {% if appt.customerType == 'guest' %}
                                    <span class="tag tag-guest">Guest</span>
                                {% else %}
                                    <span class="tag tag-client">Client</span>
                                {% endif %}
                            </div>
                            <span class="status-chip status-chip-{{ appt.status }}">{{ appt.status|capitalize }}</span>
                        </header>

                        <dl class="appt-details">
                            <div class="appt-field"><dt>Service</dt><dd>{{ appt.serviceName }}</dd></div>
                            <div class="appt-field"><dt>Date &amp; Time</dt><dd>{{ appt.date }} · {{ appt.time }}</dd></div>
                            <div class="appt-field"><dt>Email</dt><dd>{{ appt.customerEmail|default('—') }}</dd></div>
                            <div class="appt-field"><dt>Phone</dt><dd>{{ appt.customerPhone|default('—') }}</dd></div>
                        </dl>

                        <footer class="appt-card-actions">
                            <a class="btn-sm" href="{{ path('/admin/appointments/' ~ appt.id ~ '/edit') }}">Edit</a>
                            {% if appt.status != 'cancelled' %}
                                <form method="post"
                                      action="{{ path('/admin/appointments/' ~ appt.id ~ '/cancel') }}"
                                      data-confirm="Cancel this appointment for {{ appt.customerName }}? They'll need to rebook."
                                      data-confirm-title="Cancel appointment"
                                      data-confirm-danger
                                      style="display:inline;">
                                    <button type="submit" class="btn-sm btn-sm-danger">Cancel</button>
                                </form>
                            {% endif %}
                        </footer>
                    </article>
                {% else %}
                    <p class="muted">No appointments scheduled.</p>
                {% endfor %}
            </div>
        {% endif %}
    </section>
</main>

{% include 'partials/confirm-modal.twig' %}
{% endblock %}
