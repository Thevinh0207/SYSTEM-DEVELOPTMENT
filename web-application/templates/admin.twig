{% extends 'layout.twig' %}
{% block title %}Admin | Studio Doki{% endblock %}
{% block body_class %}admin-page{% endblock %}
{% block nav %}{% endblock %}
{% block content %}
<main class="admin-layout">
    <aside>
        <span class="admin-pill">ADMIN ONLY</span>
        <h2>Studio Doki</h2>
        {% if currentUser %}
            <p class="admin-user muted">{{ currentUser.firstName }} {{ currentUser.lastName }}</p>
        {% endif %}
        <a class="{{ section == 'appointments' ? 'active' : '' }}" href="{{ path('/admin/appointments') }}">Appointments</a>
        <a class="{{ section == 'services' ? 'active' : '' }}" href="{{ path('/admin/services') }}">Services</a>
        <a class="{{ section == 'reviews' ? 'active' : '' }}" href="{{ path('/admin/reviews') }}">Reviews</a>
        <form method="post" action="{{ path('/logout') }}" class="admin-logout">
            <button type="submit" class="btn outline">Log out</button>
        </form>
    </aside>
    <section>
        {% if section == 'services' %}
            <h1>Services</h1>
            <div class="admin-table-wrap">
                <table>
                    <tr><th>Service Name</th><th>Category</th><th>Price</th><th>Duration</th><th>Actions</th></tr>
                    {% for service in services %}
                        <tr>
                            <td>{{ service.0 }}</td><td>{{ service.1 }}</td><td>{{ service.2 }}</td><td>{{ service.3 }}</td>
                            <td><button class="icon-action">Edit</button><button class="icon-action danger">Delete</button></td>
                        </tr>
                    {% endfor %}
                </table>
            </div>
        {% elseif section == 'reviews' %}
            <h1>Customer Reviews</h1>
            {% for review in reviews|default([]) %}
                <div class="review-card">
                    <strong>{{ review.name }}</strong><span class="stars" aria-label="{{ review.rating }} stars">{{ review.rating }}/5</span>
                    <p class="muted">{{ review.meta }}</p>
                    <p>{{ review.comment }}</p>
                </div>
            {% else %}
                <p class="muted">No reviews yet.</p>
            {% endfor %}
        {% else %}
            <h1>Appointments</h1>
            <h2>Upcoming Appointments</h2>
            <div class="admin-appointment-list">
                {% for appt in appointments|default([]) %}
                    <div>
                        <strong>{{ appt.firstName }} {{ appt.lastName }} — {{ appt.serviceName }}</strong>
                        <span>{{ appt.date }} {{ appt.time }}</span>
                        <em>{{ appt.status|capitalize }}</em>
                        <button>Edit</button><button class="danger">Cancel</button>
                    </div>
                {% else %}
                    <p class="muted">No appointments scheduled.</p>
                {% endfor %}
            </div>
        {% endif %}
    </section>
</main>
{% endblock %}
