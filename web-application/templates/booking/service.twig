{% extends 'layout.twig' %}
{% block title %}Book | Studio Doki{% endblock %}
{% block content %}
<main class="booking">
    <h1>Book Your Appointment</h1>
    {% if currentUser %}
        <p class="subtitle">Step 1 of 4: Select Service</p>
    {% else %}
        <p class="subtitle">Step 3 of 6: Select Service</p>
    {% endif %}
    {% if currentUser %}
        {# Logged-in users started here — only the Home button makes sense. #}
        {% include 'partials/booking-nav.twig' %}
    {% else %}
        {% include 'partials/booking-nav.twig' with { back: '/book/info', backLabel: 'Information' } %}
    {% endif %}
    <div class="booking-grid">
        <section class="booking-services">
            {% if errors.service is defined %}<p class="error">{{ errors.service }}</p>{% endif %}
            {% for service in bookingServices %}
                <form method="post" action="{{ path('/book/service') }}">
                    <input type="hidden" name="serviceId" value="{{ service.id }}">
                    <button type="submit" class="book-card">
                        <img src="{{ images[service.image]|default(images.brush) }}" alt="{{ service.name }}">
                        <h2>{{ service.name }}</h2><span>{{ service.duration }}</span><strong>{{ service.price }}</strong>
                    </button>
                </form>
            {% else %}
                <p class="muted">No services available right now.</p>
            {% endfor %}
        </section>
        {% include 'partials/summary.twig' %}
    </div>
</main>
{% endblock %}
