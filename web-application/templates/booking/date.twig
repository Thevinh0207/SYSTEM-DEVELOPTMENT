{% extends 'layout.twig' %}
{% block title %}Book Date | Studio Doki{% endblock %}
{% block content %}
<main class="booking">
    <h1>Book Your Appointment</h1>
    <p class="subtitle">Step 2 of 6: Select Date &amp; Time</p>
    <div class="booking-grid">
        <section class="date-time">
            <form method="post" action="{{ path('/book/date') }}" novalidate>
                {% if errors.general is defined %}
                    <div class="error">{{ errors.general }}</div>
                {% endif %}

                <h2>Select Date</h2>
                <label class="block">
                    <input type="date"
                           name="date"
                           required
                           min="{{ "now"|date('Y-m-d') }}"
                           value="{{ form.date|default('') }}">
                </label>
                {% if errors.date is defined %}<p class="error">{{ errors.date }}</p>{% endif %}

                <h2>Select Time</h2>
                <label class="block">
                    <select name="time" required>
                        <option value="">— Choose a time —</option>
                        {% for time in times %}
                            <option value="{{ time }}" {{ form.time|default('') == time ? 'selected' : '' }}>{{ time }}</option>
                        {% endfor %}
                    </select>
                </label>
                {% if errors.time is defined %}<p class="error">{{ errors.time }}</p>{% endif %}

                <button class="btn continue" type="submit">Continue</button>
            </form>
        </section>
        {% include 'partials/summary.twig' %}
    </div>
</main>
{% endblock %}
