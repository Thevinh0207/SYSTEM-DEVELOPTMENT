{% extends 'layout.twig' %}
{% block title %}Book Account | Studio Doki{% endblock %}
{% block content %}
<main class="booking">
    <h1>Book Your Appointment</h1>
    <p class="subtitle">Step 3 of 6: Account</p>
    <div class="booking-grid">
        <section class="choice-list">
            <a href="{{ path('/login') }}"><strong>Log In</strong><span>Sign in to your existing account</span></a>
            <a href="{{ path('/register') }}"><strong>Create Account</strong><span>Sign up and save your preferences</span></a>
            <a class="active" href="{{ path('/book/info') }}"><strong>Continue as Guest</strong><span>Book without creating an account</span></a>
        </section>
        {% include 'partials/summary.twig' %}
    </div>
</main>
{% endblock %}
