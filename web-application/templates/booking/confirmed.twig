{% extends 'layout.twig' %}
{% block title %}Confirmed | Studio Doki{% endblock %}
{% block content %}
<main class="confirmed">
    <div class="check">✓</div>
    <h1>Appointment Confirmed!</h1>
    {% if booking.email is defined and booking.email %}
        <p>We have sent a confirmation email to {{ booking.email }}</p>
    {% endif %}
    <section class="details-card">
        <h2>Appointment Details</h2>
        <div><span>Service</span><strong>{{ booking.service|default('—') }}</strong></div>
        <div><span>Date</span><strong>{{ booking.date|default('—') }}</strong></div>
        <div><span>Time</span><strong>{{ booking.time|default('—') }}</strong></div>
        <div><span>Location</span><strong>Studio Doki</strong></div>
        {% if booking.deposit is defined %}
            <div><span>Deposit Paid</span><strong class="success">${{ booking.deposit|number_format(2) }}</strong></div>
        {% endif %}
    </section>
    <p class="notice"><strong>Important:</strong> Please arrive 5 minutes early. Cancel or reschedule at least 48 hours in advance to avoid losing your deposit.</p>
    {% if isGuest|default(false) %}
        <a class="btn" href="{{ path('/book') }}">Book another appointment</a>
    {% else %}
        <a class="btn" href="{{ path('/dashboard') }}">Go to my dashboard</a>
    {% endif %}
</main>
{% endblock %}
