<!DOCTYPE html>
<html lang="{{ locale|default('en') }}">
<head>
    <meta charset="UTF-8">
    <title>404 — Page Not Found</title>
    <style>
        body { font-family: system-ui, sans-serif; background: #fdf6f9; color: #333;
               display: flex; align-items: center; justify-content: center;
               min-height: 100vh; margin: 0; text-align: center; }
        .card { background: #fff; padding: 3rem 4rem; border-radius: 12px;
                box-shadow: 0 8px 24px rgba(0,0,0,0.06); max-width: 480px; }
        h1 { font-size: 5rem; margin: 0; color: #d6336c; }
        h2 { margin: 0.25rem 0 1rem; }
        p  { color: #666; margin-bottom: 1.5rem; }
        code { background: #f5f5f5; padding: 0.15rem 0.4rem; border-radius: 4px; }
        a.btn { display: inline-block; padding: 0.6rem 1.2rem; background: #d6336c;
                color: #fff; text-decoration: none; border-radius: 6px; }
        a.btn:hover { background: #b02a59; }
    </style>
</head>
<body>
    <div class="card">
        <h1>404</h1>
        <h2>Page not found</h2>
        <p>We couldn't find <code>{{ requestedPath }}</code>. It may have moved or never existed.</p>
        <a class="btn" href="{{ path('/') }}">Back to home</a>
    </div>
</body>
</html>
