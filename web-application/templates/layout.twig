<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Studio Doki{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('style.css') }}">
</head>
<body class="{% block body_class %}{% endblock %}">
    {% block nav %}
        <header class="site-header">
            <a class="brand" href="{{ path('/') }}"><span aria-hidden="true">&hearts;</span> Studio Doki</a>
            <nav>
                <a class="{{ active == 'home' ? 'active' : '' }}" href="{{ path('/') }}">Home</a>
                <a class="{{ active == 'services' ? 'active' : '' }}" href="{{ path('/services') }}">Services</a>
                <a class="{{ active == 'book' ? 'active' : '' }}" href="{{ path('/book?new=1') }}">Book</a>
                <a class="{{ active == 'about' ? 'active' : '' }}" href="{{ path('/about') }}">About</a>
                <a class="{{ active == 'faq' ? 'active' : '' }}" href="{{ path('/faq') }}">FAQ</a>
                {% if currentUser %}
                    <details class="user-menu">
                        <summary>{{ currentUser.firstName }}{% if currentUser.role == 'admin' %} <span class="badge">admin</span>{% endif %}</summary>
                        <div class="user-menu-panel">
                            {% if currentUser.role == 'admin' %}
                                <a href="{{ path('/admin') }}">Admin Dashboard</a>
                            {% else %}
                                <a href="{{ path('/dashboard') }}">My Dashboard</a>
                            {% endif %}
                            <form method="post" action="{{ path('/logout') }}">
                                <button type="submit">Log out</button>
                            </form>
                        </div>
                    </details>
                {% else %}
                    <a class="account-link" href="{{ path('/login') }}" aria-label="Account">Account</a>
                {% endif %}
            </nav>
        </header>
    {% endblock %}
    {% block content %}{% endblock %}

    {# Site footer — shown on every public page. Excluded from admin and the
       auth screens (which render their own minimal chrome). #}
    {% set _bodyClass = block('body_class') %}
    {% if _bodyClass != 'admin-page' and _bodyClass != 'auth-page' %}
        {% include 'partials/footer.twig' %}
    {% endif %}

    {% if globalToast %}
        <div id="global-toast" class="toast toast-{{ globalToast.type|default('success') }}" role="status" aria-live="polite">
            <span class="toast-icon">✓</span>
            <span class="toast-message">{{ globalToast.message }}</span>
        </div>
        <script>
            (function () {
                const t = document.getElementById('global-toast');
                if (!t) return;
                // Slide in, hold for 2.4s, fade out, then clean the URL.
                requestAnimationFrame(() => t.classList.add('toast-show'));
                setTimeout(() => t.classList.remove('toast-show'), 2400);
                setTimeout(() => t.remove(), 3000);
                // Strip the ?logged_out=1 from the URL so refresh doesn't replay it.
                if (history.replaceState) {
                    const u = new URL(window.location.href);
                    u.searchParams.delete('logged_out');
                    history.replaceState({}, '', u.pathname + (u.search ? u.search : '') + u.hash);
                }
            })();
        </script>
    {% endif %}
</body>
</html>
