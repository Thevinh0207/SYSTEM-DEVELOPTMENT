{% extends 'layout.twig' %}
{% block title %}Services | Studio Doki{% endblock %}
{% block content %}
<main>
    <section class="page-hero">
        <h1>Our Services</h1>
        <p>Premium nail care tailored for you</p>
    </section>

    <section class="menu-wrap">
        {% for category, rows in servicesByCat %}
            <h2>{{ category }}</h2>
            {% for row in rows %}
                <div class="menu-row">
                    <div class="menu-row-main">
                        <strong>{{ row.name }}</strong>
                        {% if row.description %}<p class="muted">{{ row.description }}</p>{% endif %}
                    </div>
                    <span class="time">{{ row.duration }}</span>
                    <span class="price">{{ row.price }}</span>
                </div>
            {% endfor %}
        {% else %}
            <p class="muted" style="text-align:center; padding: 40px;">
                No services available right now. Please check back soon.
            </p>
        {% endfor %}

        {% if servicesByCat|length > 0 %}
            <a class="btn centered" href="{{ path('/book') }}">Book Now</a>
        {% endif %}
    </section>
</main>
{% endblock %}
