{% extends 'layout.twig' %}
{% block title %}Login | Studio Doki{% endblock %}
{% block body_class %}auth-page{% endblock %}
{% block nav %}{% endblock %}
{% block content %}
<main class="auth-shell">
    <form class="auth-card" method="post" action="{{ path('/login') }}">
        <a class="brand auth-brand" href="{{ path('/') }}"><span>&hearts;</span> Studio Doki</a>
        <h1>Welcome Back</h1>
        {% if errors.general is defined %}<p class="error">{{ errors.general }}</p>{% endif %}
        <label>Email<input type="email" name="email" value="{{ form.email|default('') }}" required placeholder="you@example.com"></label>
        <label>Password<input type="password" name="password" required placeholder="Password"></label>
        <button class="btn wide">Log In</button>
        <a class="outline-btn" href="{{ path('/register') }}">Create Account</a>
        <a href="{{ path('/book/info') }}">Continue as Guest</a>
    </form>
</main>
{% endblock %}
